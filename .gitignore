# ============================================================
# Environment — archivos con credenciales reales
# ============================================================
# Los archivos environment.ts y environment.prod.ts del proyecto
# NO contienen secretos (solo URLs relativas), así que SÍ se suben.
# Si en el futuro añades API keys u otros secretos, crea
# src/environments/environment.local.ts y añádelo aquí:
# src/environments/environment.local.ts

# Archivos .env genéricos (por si se usan en el futuro)
.env
.env.*
!.env.example

